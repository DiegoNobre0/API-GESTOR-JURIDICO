generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// --------------------------------------
// Usuários e Acessos
// --------------------------------------

model User {
  id       String  @id @default(auto()) @map("_id") @db.ObjectId
  nome     String
  email    String  @unique
  senha    String
  tipo     String  @default("cliente") // 'admin' ou 'cliente'
  cpf      String?
  telefone String?

  // --- NOVOS CAMPOS PARA CONFIGURAÇÕES ---
  numeroOab          String?
  estadoOab          String?
  notificarAgenda    Boolean @default(true)
  notificarPje       Boolean @default(true)
  horarioNotificacao String  @default("07:00")
  ativo              Boolean @default(true) // Para o toggle de Status na tabela

  // Relacionamentos Reais (Back-references)
  processos          Processo[]
  compromissos       Compromisso[]
  tarefas            Tarefa[]
  transacoes         Transacao[]
  andamentos         Andamento[]
  chatHistories      ChatHistory[]
  conversasAssumidas Conversation[]

  processosVinculados String[] @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("usuarios")
}


model Cliente {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  nome      String
  // CPF e Telefone únicos para evitar duplicidade
  cpf       String?  @unique
  telefone  String   @unique
  endereco  String?
  email     String?
  
  // Um cliente pode ter vários processos
  processos Processo[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("clientes")
}

  model Processo {
    id             String   @id @default(auto()) @map("_id") @db.ObjectId
    
    // --- VINCULAÇÃO COM CLIENTE (NOVO) ---
    clienteId      String   @db.ObjectId
    cliente        Cliente  @relation(fields: [clienteId], references: [id])
    
    // Mantemos esses campos como "cache" ou snapshot se quiser, 
    // mas o ideal é puxar do cliente. Vou manter para não quebrar seu front atual.
    clienteNome    String
    clienteCpf     String?
    clienteEmail   String?

    // --- DADOS DO PROCESSO ---
    numeroInterno  String   @default(cuid())
    numeroProcesso String?
    descricaoObjeto String
    numeroCNJ         String?   
    ultimaMovimentacao DateTime?
    
    responsavel    String   // Nome do advogado (ou link com User)
    tipoHonorarios String
    statusGeral    String   @default("Triagem Inicial") // Mudado de "Contrato Fechado" para refletir a entrada via bot
    statusProtocolamento String @default("Pendente")

    // --- FINANCEIRO ---
    valorPrevistoIniciais Float @default(0)
    valorPrevistoExito    Float @default(0)
    basePrevisao          String?
    custosPrevistos       Float @default(0)
    
    // --- DATAS ---
    dataFechamentoContrato DateTime @default(now())
    dataEstimadaRecebimento DateTime?
    
    // --- RELACIONAMENTOS ---
    userId         String   @db.ObjectId
    user           User     @relation(fields: [userId], references: [id])
    
    andamentos     Andamento[]
    arquivos       ProcessoArquivo[] // Relação com os arquivos


    // --- VINCULAÇÃO COM CONVERSA (WHATSAPP) ---
    conversationId  String?       @db.ObjectId
    conversation    Conversation? @relation(fields: [conversationId], references: [id])
    compromissos    Compromisso[]
    dataArquivamento DateTime?
    arquivado      Boolean  @default(false)
    createdAt      DateTime @default(now())
    updatedAt      DateTime @updatedAt

    @@map("processos")
  }

model ProcessoArquivo {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  
  processoId  String   @db.ObjectId
  processo    Processo @relation(fields: [processoId], references: [id])
  
  tipo        String   // Ex: RG, COMP_RES, PROVAS
  url         String
  nomeArquivo String
  
  createdAt   DateTime @default(now())

  @@map("processo_arquivos")
}
// --------------------------------------
// Agenda e Tarefas
// --------------------------------------

model Compromisso {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  titulo      String
  description String?
  startDate   DateTime
  endDate     DateTime? // 👈 ADICIONADO AQUI
  
  tipo        String   @default("reuniao") // audiencia, reuniao, prazo, outro
  location    String?
  processoId  String?  @db.ObjectId
  processo    Processo? @relation(fields: [processoId], references: [id])

  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt 

  @@map("compromissos")
}

model Tarefa {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  processoId  String? 
  titulo      String
  description String
  responsavel String
  prazo       String
  concluida   Boolean @default(false)

  // Relacionamento com User
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@map("tarefas")
}

// --------------------------------------
// Financeiro e Logs
// --------------------------------------

model Transacao {
  id               String  @id @default(auto()) @map("_id") @db.ObjectId
  tipo             String // entrada ou saida
  categoria        String
  valor            Float
  data             String
  descricao        String
  processoId       String? @db.ObjectId
  recorrente       Boolean @default(false)
  mesesRecorrencia Int?
  arquivado        Boolean @default(false)
  grupoRecorrenciaId String?
  // Relacionamento com User
  createdBy String @db.ObjectId
  user      User   @relation(fields: [createdBy], references: [id])

  createdAt DateTime @default(now())

  @@map("transacoes")
}

model Andamento {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId

  processoId      String   @db.ObjectId
  processo        Processo @relation(fields: [processoId], references: [id])

  titulo          String
  descricao       String
  autorNome       String

  createdBy       String   @db.ObjectId
  user            User     @relation(fields: [createdBy], references: [id])

  // 🔥 Campos novos para integração CNJ
  codigoMovimento Int?
  dataMovimento   DateTime?
  orgaoJulgador   String?
  tribunal        String?

  createdAt       DateTime @default(now())

  @@map("andamentos")
}

model ChatHistory {
  id           String  @id @default(auto()) @map("_id") @db.ObjectId
  sessionId    String?
  userMessage  String
  botResponse  String
  action       String?
  actionResult Json?

  // Relacionamento com User
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@map("chat_history")
}

model Conversation {
  id             String  @id @default(auto()) @map("_id") @db.ObjectId
  customerPhone  String  @unique // O ID do cliente é o telefone (ex: 557199999999)
  customerName   String?
  customerAvatar String?

  status      String @default("OPEN") // OPEN, CLOSED, PENDING
  channel     String @default("whatsapp")
  unreadCount Int    @default(0)

  // Snapshot da última mensagem para a Sidebar carregar rápido
  lastMessageBody String?
  lastMessageTime DateTime @default(now())

  // Tags (Array de strings no Mongo)
  tags String[] @default([])

  workflowStep String  @default("COLETA_FATOS") // TRIAGEM, COLETA_FATOS, COLETA_DOCS, ASSINATURA, FINALIZADO
  tipoCaso     String? // VOO, BANCO, SAUDE, GERAL
  // Dados temporários que a IA coletou antes de criar o Processo oficial
  tempData     Json?
  // Relacionamento com Advogado/Atendente (Quem assumiu)
  attendantId  String? @db.ObjectId
  attendant    User?   @relation(fields: [attendantId], references: [id])

  // Relacionamento com Mensagens
  messages  Message[]
  documents ConversationDocument[]
  processos       Processo[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  presentedAt DateTime?

  @@map("conversations")
}

enum EtapaDocumento {
  ESSENCIAL
  COMPLEMENTAR
}

model ConversationDocument {
  id             String @id @default(auto()) @map("_id") @db.ObjectId
  conversationId String @db.ObjectId

  tipo          String
  
  messageId     String?  @db.ObjectId
  extractedData Json?
  fileName      String?
  mimeType      String?
  mediaUrl      String?
  etapa          EtapaDocumento
  validado      Boolean  @default(false)
  createdAt     DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id])

  @@map("conversation_documents")
}

model Message {
  id    String  @id @default(auto()) @map("_id") @db.ObjectId
  wa_id String? @unique // ID oficial da Meta (wamid.HBgL...)

  content String
  role    String // 'USER' (cliente), 'AGENT' (advogado), 'SYSTEM'

  // Status de entrega da Meta
  status String @default("sent") // sent, delivered, read, failed

  // Suporte a Multimídia (PDFs, Imagens)
  type     String  @default("text") // text, image, document, audio
  mediaUrl String?
  mimeType String?
  fileName String?

  // Relacionamento com a Conversa
  conversationId String       @db.ObjectId
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  processed      Boolean      @default(false) // 👈 ADICIONE ISSO
  createdAt      DateTime     @default(now())

  @@map("messages")
}

model AiDecisionLog {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  conversationId String   @db.ObjectId
  etapaAnterior  String
  tool           String
  payload        Json
  model          String
  createdAt      DateTime @default(now())
}
