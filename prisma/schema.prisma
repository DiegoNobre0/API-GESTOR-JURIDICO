generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// --------------------------------------
// Usuários e Acessos
// --------------------------------------

model User {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  nome                String
  email               String   @unique
  senha               String
  tipo                String   @default("cliente") // 'admin' ou 'cliente'
  cpf                 String?
  telefone            String?
  
  // Relacionamentos Reais (Back-references)
  processos           Processo[]
  compromissos        Compromisso[]
  tarefas             Tarefa[]
  transacoes          Transacao[]
  andamentos          Andamento[]
  chatHistories       ChatHistory[]

  processosVinculados String[] @db.ObjectId 
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("usuarios")
}

// --------------------------------------
// Gestão de Processos Jurídicos
// --------------------------------------

model Processo {
  id                      String   @id @default(auto()) @map("_id") @db.ObjectId
  clienteNome             String
  descricaoObjeto         String
  numeroInterno           String?
  dataFechamentoContrato  DateTime
  numeroProcesso          String?
  responsavel             String   
  tipoHonorarios          String   
  valorPrevistoIniciais   Float    @default(0)
  valorPrevistoExito      Float    @default(0)
  basePrevisao            String?
  dataEstimadaRecebimento String?
  custosPrevistos         Float    @default(0)
  statusProtocolamento    String   @default("Pendente de Protocolamento")
  statusGeral             String   @default("Contrato Fechado")
  clienteCpf              String?
  clienteEmail            String?
  
  // Financeiro Consolidado (Realidade)
  totalRecebidoIniciais   Float    @default(0)
  totalRecebidoExito      Float    @default(0)
  totalCustosReais        Float    @default(0)
  
  arquivado               Boolean  @default(false)
  dataArquivamento        DateTime?

  // Relacionamento com quem criou o processo (Advogado)
  userId               String   @db.ObjectId
  user                    User     @relation(fields: [userId], references: [id])

  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@map("processos")
}

// --------------------------------------
// Agenda e Tarefas
// --------------------------------------

model Compromisso {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  startDate   DateTime 
  titulo      String
  description String?
  tipo        String   @default("outro") 
  concluido   Boolean  @default(false)
  
  // Relacionamento com User
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])
  
  processoId  String?  @db.ObjectId
  createdAt   DateTime @default(now())

  @@map("compromissos")
}

model Tarefa {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  processoId  String?  @db.ObjectId
  titulo      String   
  description String
  responsavel String
  prazo       String
  concluida   Boolean  @default(false) 

  // Relacionamento com User
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])
  
  createdAt   DateTime @default(now())

  @@map("tarefas")
}

// --------------------------------------
// Financeiro e Logs
// --------------------------------------

model Transacao {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  tipo             String   // entrada ou saida
  categoria        String
  valor            Float
  data             String
  descricao        String
  processoId       String?  @db.ObjectId
  recorrente       Boolean  @default(false)
  mesesRecorrencia Int?
  arquivado        Boolean  @default(false)
  
  // Relacionamento com User
  createdBy        String   @db.ObjectId
  user             User     @relation(fields: [createdBy], references: [id])
  
  createdAt        DateTime @default(now())

  @@map("transacoes")
}

model Andamento {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  processoId String   @db.ObjectId
  titulo     String
  descricao  String
  autorNome  String
  
  // Relacionamento com User
  createdBy  String   @db.ObjectId
  user       User     @relation(fields: [createdBy], references: [id])
  
  createdAt  DateTime @default(now())

  @@map("andamentos")
}

model ChatHistory {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionId     String?
  userMessage   String
  botResponse   String
  action        String?
  actionResult  Json?
  
  // Relacionamento com User
  userId        String   @db.ObjectId
  user          User     @relation(fields: [userId], references: [id])
  
  createdAt     DateTime @default(now())

  @@map("chat_history")
}